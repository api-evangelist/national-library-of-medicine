        {
          "id": "55f4c34e-4d3b-490b-acd2-0b15f25f9b23",
          "name": "Search a database",
          "request": {
            "name": "Search a database",
            "description": {
              "content": "Returns a list of UIDs matching a text query, optionally posting the results to the Entrez History server for downstream operations.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "esearch.fcgi"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "db",
                  "value": "pubmed",
                  "description": "(Required) Database to search (e.g. pubmed, pmc, gene, protein, nuccore)."
                },
                {
                  "disabled": false,
                  "key": "term",
                  "value": "<string>",
                  "description": "(Required) Entrez text query, URL-encoded."
                },
                {
                  "disabled": false,
                  "key": "usehistory",
                  "value": "<string>",
                  "description": "Set to 'y' to post UIDs to the History server."
                },
                {
                  "disabled": false,
                  "key": "retmax",
                  "value": "<integer>",
                  "description": "Maximum number of UIDs to return (default 20, max 10000)."
                },
                {
                  "disabled": false,
                  "key": "retstart",
                  "value": "<integer>",
                  "description": "Sequential index of the first UID to return (zero-based)."
                },
                {
                  "disabled": false,
                  "key": "retmode",
                  "value": "<string>",
                  "description": "Output format."
                },
                {
                  "disabled": false,
                  "key": "api_key",
                  "value": "<string>",
                  "description": "NCBI API key for higher rate limits."
